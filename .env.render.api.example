# Render API Service (imengle.onrender.com)
# One port only. Render injects PORT automatically.

# Core app
SPRING_PROFILES_ACTIVE=prod
WEB_APPLICATION_TYPE=servlet
SOCKETIO_ENABLED=false

# Required secrets
MONGODB_URI=replace_with_your_mongodb_connection_string
# Use either a Base64 string or a plain text secret with at least 32 characters.
JWT_SECRET=replace-with-a-very-long-secret-at-least-32-chars

# CORS for frontend origin(s)
APP_CORS_ALLOWED_ORIGINS=https://imengle.netlify.app,https://www.imengle.netlify.app

# Optional
LOG_LEVEL=INFO
